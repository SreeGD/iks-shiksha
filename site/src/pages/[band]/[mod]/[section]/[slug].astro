---
import { withBase } from '../../../../utils/path';
/** Generic doc route for nested per-pack files:
 *    /[band]/[mod]/quizzes/{file}/
 *    /[band]/[mod]/activities/{file}/
 *    /[band]/[mod]/assessments/{file}/
 *    /[band]/[mod]/slides/deck/
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { BAND_LABELS, MODULE_TITLES, prettyFileName } from '../../../../utils/labels';

const SECTIONS = ['quizzes', 'activities', 'assessments', 'slides'];

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter((d) => {
      const parts = d.id.split('/');
      return parts.length === 4 && ['quizzes', 'activities', 'assessments', 'slides'].includes(parts[2]);
    })
    .map((doc) => {
      const [b, m, s, f] = doc.id.split('/');
      return { params: { band: b, mod: m, section: s, slug: f }, props: { doc } };
    });
}

const { band, mod, section, slug } = Astro.params;
type Band = 'primary' | 'middle' | 'senior';
const b = band as Band;
const { doc } = Astro.props;
const { Content } = await render(doc);

const moduleTitle = MODULE_TITLES[mod] ?? mod;
const fileLabel = prettyFileName(slug);
const sectionLabel = section.charAt(0).toUpperCase() + section.slice(1);
const moduleNumber = mod.match(/^module-(\d+)/)?.[1] ?? '?';
---

<BaseLayout title={`${fileLabel} — ${moduleTitle}`} band={b}>
  <Header activeBand={b} />

  <main class="flex-1 max-w-content mx-auto px-6 py-10 w-full">
    <nav class="text-sm text-text-muted mb-4">
      <a href={withBase("/")} class="text-accent-2">Home</a> ›
      <a href={withBase(`/${band}/`)} class="text-accent-2">{BAND_LABELS[b]}</a> ›
      <a href={withBase(`/${band}/${mod}/`)} class="text-accent-2">Module {parseInt(moduleNumber)}</a> ›
      {sectionLabel} › {fileLabel}
    </nav>

    <article class="prose prose-lg max-w-none">
      <Content />
    </article>

    <nav class="mt-10 pt-6 border-t border-border text-sm">
      ← <a href={withBase(`/${band}/${mod}/`)} class="text-accent hover:underline">Back to module overview</a>
    </nav>
  </main>

  <Footer />
</BaseLayout>
