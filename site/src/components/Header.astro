---
import { withBase } from '../utils/path';
import SearchModal from './SearchModal.astro';
import ShortcutsOverlay from './ShortcutsOverlay.astro';
import ThemeToggle from './ThemeToggle.astro';
import PathBadge from './PathBadge.astro';

interface Props {
  activeBand?: 'primary' | 'middle' | 'senior';
}
const { activeBand } = Astro.props;
---

<SearchModal />
<ShortcutsOverlay />

<header class="bg-accent text-white">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-3 flex items-center justify-between gap-4 relative">
    <h1 class="text-base md:text-lg font-bold m-0">
      <a href={withBase("/")} class="text-white no-underline">IKS Curriculum</a>
    </h1>

    {/* Mobile hamburger (checkbox-hack, no JS) */}
    <input type="checkbox" id="nav-toggle" class="peer hidden" />
    <label
      for="nav-toggle"
      class="md:hidden cursor-pointer text-2xl leading-none px-3 py-1 rounded bg-white/10 hover:bg-white/20"
      aria-label="Toggle menu"
    >☰</label>

    <nav
      class="hidden peer-checked:flex md:flex flex-col md:flex-row absolute md:static top-full left-0 right-0 md:left-auto md:right-auto bg-accent md:bg-transparent gap-3 md:gap-5 px-6 md:px-0 py-4 md:py-0 text-sm shadow-lg md:shadow-none z-50"
    >
      <a href={withBase("/primary/")} class={`text-white hover:underline ${activeBand === 'primary' ? 'underline' : ''}`}>Primary</a>
      <a href={withBase("/middle/")} class={`text-white hover:underline ${activeBand === 'middle' ? 'underline' : ''}`}>Middle</a>
      <a href={withBase("/senior/")} class={`text-white hover:underline ${activeBand === 'senior' ? 'underline' : ''}`}>Senior</a>
      <a href={withBase("/darshana/")} class="text-white hover:underline">Workshops</a>
      <a href={withBase("/glossary/")} class="text-white hover:underline">Glossary</a>
      <a href={withBase("/downloads/")} class="text-white hover:underline">Downloads</a>
      <a href={withBase("/attribution/")} class="text-white hover:underline">Attribution</a>
      <button
        onclick="window.iksOpenSearch && window.iksOpenSearch()"
        class="text-white hover:underline flex items-center gap-1 text-sm"
        title="Search (Cmd+K)"
      >🔍 <span class="hidden lg:inline">Search</span> <kbd class="hidden xl:inline text-xs opacity-75">⌘K</kbd></button>
    </nav>

    {/* Theme toggle + Path badge + Audience badge */}
    <div class="hidden md:flex items-center gap-1 relative">
      <ThemeToggle />
      <PathBadge />
      <details class="audience-badge">
        <summary
          class="cursor-pointer list-none px-3 py-1 rounded text-xs bg-white/15 hover:bg-white/25 text-white border border-white/20"
        >
          <span class="audience-label" data-mode="unset">👋 Pick audience</span>
          <span class="audience-label hidden" data-mode="teacher">👨‍🏫 Teacher</span>
          <span class="audience-label hidden" data-mode="parent">👪 Parent</span>
          <span class="audience-label hidden" data-mode="student">👧 Student</span>
        </summary>
        <div class="absolute right-0 mt-1 bg-surface text-text border border-border rounded shadow-lg p-1 min-w-[140px] z-50">
          <button data-set-audience="teacher" class="block w-full text-left px-3 py-2 hover:bg-bg rounded text-sm">👨‍🏫 Teacher</button>
          <button data-set-audience="parent" class="block w-full text-left px-3 py-2 hover:bg-bg rounded text-sm">👪 Parent</button>
          <button data-set-audience="student" class="block w-full text-left px-3 py-2 hover:bg-bg rounded text-sm">👧 Student</button>
        </div>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  // Show the active audience label, set on click.
  function updateAudienceLabel() {
    const mode = document.documentElement.dataset.audience || 'unset';
    document.querySelectorAll('.audience-label').forEach((el) => {
      el.classList.toggle('hidden', el.dataset.mode !== mode);
    });
  }
  updateAudienceLabel();
  document.addEventListener('iks-audience-change', updateAudienceLabel);
  document.querySelectorAll('[data-set-audience]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.setAudience;
      try { localStorage.setItem('iks-audience', v); } catch (e) {}
      document.documentElement.setAttribute('data-audience', v);
      document.dispatchEvent(new CustomEvent('iks-audience-change', { detail: v }));
      // close the dropdown
      const details = btn.closest('details');
      if (details) details.open = false;
    });
  });
</script>
